generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String
  config       Json?
  code         String?
  securityTier String   @default("full")
  enabled      Boolean  @default(true)
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AutonomousSettings {
  id               String   @id @default("default")
  enabled          Boolean  @default(false)
  policyLevel      String   @default("conservative")
  autoConfigure    Boolean  @default(true)
  autoUpgradeSafe  Boolean  @default(true)
  resumeOnRestart  Boolean  @default(true)
  lastConfiguredAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AutonomousAgent {
  id             String               @id
  name           String
  description    String
  cronExpression String
  skills         Json
  status         String               @default("idle")
  lastRun        DateTime?
  nextRun        DateTime?
  executionCount Int                  @default(0)
  successCount   Int                  @default(0)
  failureCount   Int                  @default(0)
  enabled        Boolean              @default(true)
  config         Json
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  runs           AutonomousAgentRun[]
}

model AutonomousAgentRun {
  id        String          @id @default(cuid())
  agentId   String
  status    String
  duration  Int
  output    Json?
  error     String?
  createdAt DateTime        @default(now())
  agent     AutonomousAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
}

model AutonomousUpgradeJob {
  id                 String   @id
  targetId           String
  targetName         String
  summary            String
  requestMessage     String
  approvalTier       String
  approvalRequired   Boolean  @default(true)
  autoExecute        Boolean  @default(false)
  approvalRationale  String
  status             String
  recommendedRepos   Json
  report             Json?
  createdBy          String   @default("AgentBrowser")
  autoCreated        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
  @@index([targetId])
}

// Phase 0: Agent Memory Bus — cross-agent shared KV store
model AgentMemory {
  id        String    @id @default(cuid())
  agentId   String
  namespace String    @default("default")
  key       String
  value     String    // JSON-stringified
  expiresAt DateTime? // null = permanent; entries past this date are stale
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([namespace, key])
  @@index([namespace, agentId, expiresAt])
}

// Phase 0: Agent Event Bus — durable event store
model AgentEvent {
  id        String   @id @default(cuid())
  type      String
  source    String
  timestamp DateTime @default(now())
  payload   String   // JSON
  durable   Boolean  @default(false)

  @@index([type])
  @@index([source])
  @@index([timestamp])
}

// Phase 0: DAG Orchestrator — pipeline definitions
model AgentPipeline {
  id         String              @id @default(cuid())
  name       String
  definition String              // JSON: { nodes: [...], edges: [...] }
  schedule   String?             // optional cron expression
  enabled    Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  runs       AgentPipelineRun[]
}

// Phase 0: DAG Orchestrator — pipeline execution runs
model AgentPipelineRun {
  id          String        @id @default(cuid())
  pipelineId  String
  pipeline    AgentPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  status      String        @default("pending") // pending | running | completed | failed | aborted
  results     String?       // JSON: per-node outputs
  startedAt   DateTime      @default(now())
  completedAt DateTime?

  @@index([pipelineId, startedAt])
  @@index([status])
}
