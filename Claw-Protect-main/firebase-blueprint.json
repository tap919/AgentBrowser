{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claw Protect Firebase Blueprint",
  "description": "Schema definitions for Firestore collections used by Claw Protect.",
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile and security settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID", "minLength": 1 },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name", "maxLength": 128 },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role for RBAC" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp (ISO 8601)" },
        "lastLoginAt": { "type": "string", "format": "date-time", "description": "Most recent login timestamp (ISO 8601)" }
      },
      "required": ["uid", "email", "role", "createdAt"],
      "additionalProperties": false
    },
    "Telemetry": {
      "title": "Telemetry",
      "description": "Security telemetry signal from a monitored agent or endpoint.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID (Firebase Auth)", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time", "description": "Signal timestamp (ISO 8601)" },
        "threatLevel": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Composite threat score (0 = safe, 100 = critical)"
        },
        "endpoint": {
          "type": "object",
          "description": "Endpoint telemetry data",
          "properties": {
            "agentId": { "type": "string", "description": "Agent identifier" },
            "hostname": { "type": "string", "description": "Endpoint hostname" },
            "ipAddress": { "type": "string", "format": "ipv4", "description": "Agent IP address" },
            "osType": { "type": "string", "enum": ["linux", "macos", "windows", "container"], "description": "Operating system type" },
            "uptimeSeconds": { "type": "integer", "minimum": 0, "description": "Agent uptime in seconds" }
          },
          "required": ["agentId"]
        },
        "network": {
          "type": "object",
          "description": "Network-level telemetry",
          "properties": {
            "outboundTransfers": { "type": "integer", "minimum": 0, "description": "Outbound transfer count in window" },
            "totalBytesOut": { "type": "integer", "minimum": 0, "description": "Total bytes transferred out" },
            "suspiciousDestinations": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Destinations flagged as suspicious"
            },
            "beaconingDetected": { "type": "boolean", "description": "Whether periodic beaconing was detected" }
          }
        },
        "dlp": {
          "type": "object",
          "description": "Data Loss Prevention telemetry",
          "properties": {
            "secretsFound": { "type": "integer", "minimum": 0, "description": "Number of exposed secrets detected" },
            "sensitiveDataTypes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Types of sensitive data detected (e.g., aws_key, github_token)"
            },
            "exfiltrationRisk": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"],
              "description": "Current exfiltration risk level"
            }
          }
        },
        "identity": {
          "type": "object",
          "description": "Identity and trust telemetry",
          "properties": {
            "agentId": { "type": "string", "description": "Agent identity" },
            "trustScore": { "type": "number", "minimum": 0, "maximum": 100, "description": "Dynamic trust score" },
            "authMethod": {
              "type": "string",
              "enum": ["challenge-response", "mTLS", "jwt", "api-key"],
              "description": "Authentication method in use"
            },
            "spoofingAttempts": { "type": "integer", "minimum": 0, "description": "Spoofing attempts detected" }
          }
        }
      },
      "required": ["uid", "timestamp", "threatLevel"],
      "additionalProperties": false
    },
    "Alert": {
      "title": "Alert",
      "description": "Security alert generated by the Claw Protect detection engine.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID (Firebase Auth)", "minLength": 1 },
        "type": {
          "type": "string",
          "description": "Alert category",
          "enum": [
            "prompt_injection",
            "behavioral_drift",
            "secret_exposure",
            "excessive_permissions",
            "data_exfiltration",
            "identity_spoofing",
            "supply_chain",
            "shadow_agent",
            "runaway_loop",
            "resource_exhaustion",
            "ransomware",
            "zero_trust_violation",
            "iot_anomaly",
            "cloud_misconfiguration"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Alert severity (lowercase, four-tier)"
        },
        "message": { "type": "string", "maxLength": 1000, "description": "Human-readable alert description" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Alert timestamp (ISO 8601)" },
        "moduleSource": { "type": "string", "description": "Security module that generated this alert" },
        "agentId": { "type": "string", "description": "Agent that triggered the alert" },
        "resolved": { "type": "boolean", "default": false, "description": "Whether the alert has been resolved" },
        "resolvedAt": { "type": "string", "format": "date-time", "description": "Resolution timestamp (ISO 8601)" }
      },
      "required": ["uid", "type", "severity", "message", "timestamp"],
      "additionalProperties": false
    },
    "SecurityConfig": {
      "title": "SecurityConfig",
      "description": "Per-tenant security configuration and module settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "Config schema version (semver)" },
        "modules": {
          "type": "object",
          "description": "Module-level enable/disable flags and thresholds",
          "properties": {
            "promptInjection": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "sensitivity": { "type": "string", "enum": ["low", "medium", "high"] }
              },
              "required": ["enabled"]
            },
            "agentMonitor": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "runawayThreshold": { "type": "integer", "minimum": 10 },
                "runawayWindowMinutes": { "type": "integer", "minimum": 1 }
              },
              "required": ["enabled"]
            },
            "secretsScanner": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "autoRedact": { "type": "boolean" }
              },
              "required": ["enabled"]
            },
            "dataExfiltration": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "maxTransferBytes": { "type": "integer", "minimum": 0 },
                "trustedDomains": { "type": "array", "items": { "type": "string" } }
              },
              "required": ["enabled"]
            },
            "zeroTrust": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "minTrustScore": { "type": "number", "minimum": 0, "maximum": 100 }
              },
              "required": ["enabled"]
            }
          }
        },
        "pricingTier": {
          "type": "string",
          "enum": ["free", "starter", "pro", "enterprise"],
          "description": "Active pricing tier"
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp (ISO 8601)" }
      },
      "required": ["uid", "version", "modules", "pricingTier"],
      "additionalProperties": false
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by Firebase Auth UID"
    },
    "/telemetry/{telemetryId}": {
      "schema": "Telemetry",
      "description": "Security telemetry logs (append-only, auto-TTL 90 days)"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Security alerts with lifecycle tracking"
    },
    "/configs/{userId}": {
      "schema": "SecurityConfig",
      "description": "Per-user/tenant security configuration"
    }
  }
}
