async function runFullAudit(){
  if(S.auditRunning)return;S.auditRunning=true;
  switchRP('chat');addMsg('user','/audit — Run full codebase audit');setBusy(true);
  await typeMsg('Initiating full codebase audit. Running 7 scan categories: static analysis, security, code smells, race conditions, memory leaks, type safety, and dependency health. This catches what "done" often misses.');
  await wait(300);
  const planEl=addPlanBlock(auditScans.map(s=>({label:s.name,name:s.id})));
  await wait(400);

  let totalFindings=0,critical=0,high=0,medium=0,low=0,info=0;
  for(let i=0;i<auditScans.length;i++){
    const scan=auditScans[i];
    const pEl=planEl.querySelectorAll('.plan-st');if(pEl[i])pEl[i].className='plan-st rn';
    const te=addToolBlk(`audit_${scan.id}`,{scan:scan.name,scope:'src/'},'aud');
    await wait(600+Math.random()*1400);
    const fCount=scan.findings.length;
    scan.findings.forEach(f=>{totalFindings++;if(f.sev==='critical')critical++;else if(f.sev==='high')high++;else if(f.sev==='medium')medium++;else if(f.sev==='low')low++;else info++});
    const hasCritical=scan.findings.some(f=>f.sev==='critical'||f.sev==='high');
    completeTool(te,Math.floor(600+Math.random()*1400),`${fCount} findings${hasCritical?' — action required':''}`);
    if(pEl[i])pEl[i].className='plan-st dn';
    await wait(200);
  }

  await wait(300);
  let summary=`Audit complete. **${totalFindings} findings** across 7 scans:\n\n`;
  if(critical)summary+=`• ${critical} CRITICAL — must fix before deploy\n`;
  if(high)summary+=`• ${high} HIGH — fix before next release\n`;
  if(medium)summary+=`• ${medium} MEDIUM — plan to address soon\n`;
  if(low)summary+=`• ${low} LOW — improve when convenient\n`;
  if(info)summary+=`• ${info} INFO — suggestions for improvement\n`;
  summary+=`\nTop priorities:\n1. **SQL injection** in handlers.ts:89 — parameterize the query\n2. **Token refresh race condition** in token.ts:47 — add mutex\n3. **Event listener leak** in websocket.ts:28 — remove on disconnect\n\nUse \`/fix\` to auto-fix what can be automated, or I can address each one individually.`;
  await typeMsg(summary);

  // Render audit results in viewport
  renderAuditResults();
  toast(`Audit: ${totalFindings} findings (${critical} critical)`,'err');
  setBusy(false);S.auditRunning=false;
}

async function runQuickAudit(){
  if(S.auditRunning)return;S.auditRunning=true;
  switchRP('chat');addMsg('user','/audit-quick — Quick security + types scan');setBusy(true);
  await typeMsg('Running quick audit: security vulnerabilities + type safety only. Faster scan for mid-build checks.');
  await wait(300);
  const quickScans=auditScans.filter(s=>s.id==='security'||s.id==='types');
  for(const scan of quickScans){
    const te=addToolBlk(`audit_${scan.id}`,{scan:scan.name,scope:'src/'},'aud');
    await wait(800+Math.random()*800);
    completeTool(te,Math.floor(800+Math.random()*800),`${scan.findings.length} findings`);
    await wait(200);
  }
  const secF=auditScans.find(s=>s.id==='security').findings;
  const typF=auditScans.find(s=>s.id==='types').findings;
  await typeMsg(`Quick scan complete. Security: ${secF.length} findings (${secF.filter(f=>f.sev==='critical').length} critical). Type safety: ${typF.length} findings. ${secF.some(f=>f.sev==='critical')?'**Critical SQL injection found** — fix before any deploy.':''} Use \`/audit\` for the full 7-scan audit.`);
  toast('Quick audit done','ok');setBusy(false);S.auditRunning=false;
}

