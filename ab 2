   ═══════════════════════════════════════════ */
const cmdPalItems=[
  ...slashCmds.map(c=>({label:c.cmd,desc:c.desc,icon:c.icon,color:c.color,action:()=>{hideCmdPal();if(c.fn)c.fn();else agentCmd(c.action)}})),
  ...Object.values(agents).map(a=>({label:`Agent: ${a.name}`,desc:a.role,icon:'fas fa-user',color:a.avClass.includes('hermes')?'var(--hermes)':a.avClass.includes('arch')?'#6366f1':a.avClass.includes('code')?'var(--acc)':'var(--cy)',action:()=>{hideCmdPal();switchAgent(a.id);switchRP('chat');toast(`Switched to ${a.name}`,'ok')}})),
  {label:'Run Full Audit',desc:'7-scan codebase audit',icon:'fas fa-shield-halved',color:'var(--hermes)',action:()=>{hideCmdPal();runFullAudit()}},
  {label:'Quick Scan',desc:'Security + types only',icon:'fas fa-stethoscope',color:'var(--hermes)',action:()=>{hideCmdPal();runQuickAudit()}},
];
function showCmdPal(){$('#cmd-pal').classList.add('show');$('#cp-input').value='';$('#cp-input').focus();renderCP('')}
function hideCmdPal(){$('#cmd-pal').classList.remove('show')}
 $('#cmd-pal').onclick=e=>{if(e.target.id==='cmd-pal')hideCmdPal()};
function renderCP(q){q=q.toLowerCase();const f=cmdPalItems.filter(i=>i.label.toLowerCase().includes(q)||i.desc.toLowerCase().includes(q)).slice(0,10);$('#cp-list').innerHTML=f.map((i,idx)=>`<div class="cp-item${idx===0?' sel':''}" onclick="cmdPalItems.find(x=>x.label==='${esc(i.label)}')?.action()"><div class="ci-icon" style="background:${i.color.includes('var')?'':'20'};color:${i.color}"><i class="${i.icon}"></i></div><span class="ci-label">${esc(i.label)}</span><span class="ci-hint">${esc(i.desc)}</span></div>`).join('')}
 $('#cp-input').addEventListener('input',e=>renderCP(e.target.value));
 $('#cp-input').addEventListener('keydown',e=>{if(e.key==='Enter'){$('.cp-item.sel')?.click()}if(e.key==='Escape')hideCmdPal()});

/* ═══════════════════════════════════════════
   TERMINAL
   ═══════════════════════════════════════════ */
function toggleTerm(){S.termOn=!S.termOn;$('#tw').classList.toggle('open',S.termOn)}
function addTL(html){const b=$('#tbody'),d=document.createElement('div');d.className='tl';d.innerHTML=html;b.appendChild(d);b.scrollTop=b.scrollHeight}
function addTC(cmd,out){addTL(`<span class="p">$</span> <span class="c">${esc(cmd)}</span>`);if(out)addTL(`<span class="o">${esc(out)}</span>`)}
function addTI(){const b=$('#tbody'),ex=b.querySelector('.ti-line');if(ex)ex.remove();const d=document.createElement('div');d.className='tl ti-line';d.innerHTML='<span class="p">$</span> <input type="text" spellcheck="false" aria-label="Terminal input">';b.appendChild(d);const inp=d.querySelector('input');inp.focus();inp.addEventListener('keydown',e=>{if(e.key==='Enter'){const c=inp.value.trim();if(!c)return;d.innerHTML=`<span class="p">$</span> <span class="c">${esc(c)}</span>`;procCmd(c);addTI()}});b.scrollTop=b.scrollHeight}
function procCmd(c){const b=c.split(/\s+/)[0].toLowerCase();const r={help:'Commands: ls, pwd, git, npm, wrangler, opencode, audit, mcp, clear',ls:'src/  public/  package.json  tsconfig.json',pwd:'~/projects/my-project',clear:null,git:'On branch main\nM src/auth.ts, M src/api.ts',npm:'Build succeeded (3.2s)',audit:'Run /audit for full scan or /audit-quick for security+types',mcp:'5 servers connected, 35+ tools available',opencode:'OpenCode agent ready'};const o=r[b];if(o===null){$('#tbody').innerHTML=''}else if(o)addTL(`<span class="o">${esc(o)}</span>`);else addTL(`<span class="o" style="color:var(--rd)">command not found: ${esc(b)}</span>`)}
function initTerm(){$('#tbody').innerHTML='';addTL('<span style="color:var(--hermes)">AgentBrowser Terminal — Hermes</span>');addTL('<span class="o">Type <span style="color:var(--tl)">help</span> for commands. Ctrl+\` to toggle.</span>');addTI()}

/* ═══════════════════════════════════════════
   KEYBOARD SHORTCUTS
   ═══════════════════════════════════════════ */
document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='k'){e.preventDefault();$('#ci').focus()}
  if((e.ctrlKey||e.metaKey)&&e.key==='p'){e.preventDefault();showCmdPal()}
  if((e.ctrlKey||e.metaKey)&&e.key==='t'){e.preventDefault();createTab('agent://home')}
  if((e.ctrlKey||e.metaKey)&&e.key==='w'){e.preventDefault();closeTab(S.at)}
  if((e.ctrlKey||e.metaKey)&&e.key==='`'){e.preventDefault();toggleTerm()}
  if(e.key==='Escape'){hideCmdPal();document.activeElement.blur()}
});

/* ═══════════════════════════════════════════
   INIT
   ═══════════════════════════════════════════ */
function init(){
  renderTabs();renderVP('agent://home');updSugs('agent://home');initTerm();
  setTimeout(async()=>{
    await typeMsg('Hermes 3 online. I\'m your default agent — cost-efficient at $0.80/$2.40 per 1M tokens via OpenRouter. I\'m updated with the NousResearch repo.\n\nKey feature: **One-button audit** (click the shield icon or /audit). This runs 7 scans — static analysis, security, code smells, race conditions, memory leaks, type safety, and dependency health — catching what "done" often misses. Use it at any point in the build process.\n\n8 MCP servers loaded from modelcontextprotocol. 9 skills from aider, fabric, browser-use, crewAI, continue, and open-interpreter. Try /audit to start.');
  },400);
}
init();
