function addMsg(role,html){const c=$('#cm'),d=document.createElement('div');d.className=`msg msg-${role==='user'?'u':'a'}`;d.innerHTML=role==='user'?html:`<span class="av ${agents[S.activeAgent].avClass}" style="width:18px;height:18px;border-radius:4px;display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:800;color:#000;vertical-align:middle;margin-right:3px">${agents[S.activeAgent].av}</span>${html}`;c.appendChild(d);c.scrollTop=c.scrollHeight;return d}

async function typeMsg(text){const c=$('#cm'),d=document.createElement('div');d.className='msg msg-a';const a=agents[S.activeAgent];const av=`<span class="av ${a.avClass}" style="width:18px;height:18px;border-radius:4px;display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:800;color:#000;vertical-align:middle;margin-right:3px">${a.av}</span>`;const sp=document.createElement('span');d.innerHTML=av;d.appendChild(sp);c.appendChild(d);let i=0;return new Promise(r=>{(function t(){if(i<text.length){sp.textContent=text.slice(0,++i);c.scrollTop=c.scrollHeight;setTimeout(t,8+Math.random()*4)}else r()})()})}

function addPlanBlock(steps){const c=$('#cm'),d=document.createElement('div');d.className='plan-blk';const uid=Date.now();d.innerHTML=`<div class="plan-hdr"><i class="fas fa-route" style="color:var(--cy);font-size:9px"></i>Execution Plan<span style="margin-left:auto;font-size:8px;color:var(--tx2)">${steps.length} steps</span></div>${steps.map((s,i)=>`<div class="plan-st pn" id="ps-${uid}-${i}"><span class="sn">${i+1}</span><span class="st">${s.label||s.name}</span></div>`).join('')}`;c.appendChild(d);c.scrollTop=c.scrollHeight;return d}

function addToolBlk(tool,params,type='nav'){const c=$('#cm'),d=document.createElement('div');d.className='tool-blk';const ph=Object.entries(params).map(([k,v])=>`<span class="pk">${k}</span>: <span class="pv">${typeof v==='string'?`"${v}"`:v}</span>`).join('<br>');d.innerHTML=`<div class="tool-h"><span class="ti ${type}"><i class="fas fa-${type==='nav'?'compass':type==='mut'?'wrench':type==='aud'?'shield-halved':'eye'}"></i></span><span class="tn">${tool}</span><span class="ts run"><i class="fas fa-spinner fa-spin"></i></span></div><div class="tool-p">${ph}</div><div class="tool-r" style="display:none"></div>`;c.appendChild(d);c.scrollTop=c.scrollHeight;return d}
function completeTool(el,dur,res,ok=true){el.querySelector('.ts').className='ts ok';el.querySelector('.ts').innerHTML='<i class="fas fa-check"></i>';const r=el.querySelector('.tool-r');r.style.display='flex';r.className=`tool-r ${ok?'ok':'err'}`;r.innerHTML=`<i class="fas fa-${ok?'check-circle':'triangle-exclamation'}"></i> ${res}`}

function addApproval(title,desc){return new Promise(resolve{const c=$('#cm'),d=document.createElement('div');d.className='appr-blk';d.innerHTML=`<div class="at"><i class="fas fa-shield-halved"></i>Approval Required</div><div class="ad"><b>${esc(title)}</b><br>${esc(desc)}</div><div class="abtn"><button class="ba" onclick="_ar(true)">Approve</button><button class="bd" onclick="_ar(false)">Deny</button></div>`;c.appendChild(d);c.scrollTop=c.scrollHeight;S.apprResolve=resolve})}
function _ar(v){if(S.apprResolve){S.apprResolve(v);S.apprResolve=null}}

function setBusy(b){S.busy=b;$('#sb').disabled=b}

/* ── Slash command autocomplete ── */
const ciEl=$('#ci');
ciEl.addEventListener('input',e=>{const v=e.target.value;if(v.startsWith('/')&&!v.includes(' ')){const q=v.slice(1).toLowerCase();const m=slashCmds.filter(c=>c.cmd.slice(1).startsWith(q)).slice(0,6);if(m.length){renderSlashDD(m)}else{$('#slash-dd').classList.remove('show')}}else{$('#slash-dd').classList.remove('show')}});
ciEl.addEventListener('keydown',e=>{const dd=$('#slash-dd');if(!dd.classList.contains('show'))return;if(e.key==='Tab'||e.key==='Enter'){e.preventDefault();const sel=dd.querySelector('.slash-item.sel');if(sel)sel.click()}else if(e.key==='Escape'){dd.classList.remove('show')}});
function renderSlashDD(matches){const dd=$('#slash-dd');dd.innerHTML=matches.map((m,i)=>`<div class="slash-item${i===0?' sel':''}" onclick="selectSlash('${m.cmd}')"><div class="si-icon" style="background:${m.color}20;color:${m.color}"><i class="${m.icon}"></i></div><span class="si-name">${m.cmd}</span><span class="si-desc">${esc(m.desc)}</span></div>`).join('');dd.classList.add('show')}
function selectSlash(cmd){const m=slashCmds.find(c=>c.cmd===cmd);if(m){$('#ci').value=m.action||cmd+' ';$('#ci').focus();$('#slash-dd').classList.remove('show')}}

/* ── Workflow engine ── */
const wfs=[
  {m:/\/audit$|^run.*full.*audit/i,fn:()=>runFullAudit()},
  {m:/\/audit-quick|^quick.*audit|^quick.*scan/i,fn:()=>runQuickAudit()},
  {m:/\/fix|^auto.*fix|^fix.*audit/i,ack:()=>'Auto-fixing audit findings. I\'ll address each category systematically.',
    exec:async()=>[
      {tool:'audit_fix',params:{category:'security',action:'parameterize SQL queries'},type:'aud',dur:1200,res:'SQL injection fixed'},
      {tool:'audit_fix',params:{category:'race_conditions',action:'add mutex to token refresh'},type:'aud',dur:900,res:'Race condition fixed'},
      {tool:'audit_fix',params:{category:'leaks',action:'remove event listeners on disconnect'},type:'aud',dur:800,res:'Memory leak fixed'},
      {tool:'terminal_execute',params:{command:'npm audit fix'},type:'mut',dur:1400,res:'3 vulnerabilities patched',act:()=>addTC('npm audit fix','added 2 packages, changed 4 packages, patched 3 vulnerabilities')},
    ],done:()=>'Auto-fix applied to 4 findings: SQL injection parameterized, mutex added to token refresh, event listener leak patched, and 3 dependency CVEs resolved. Run `/audit` to verify the fixes.'},
  {m:/create.*(?:repo|repository).*?(\w[\w-]*)/i,ack:mr=>`Creating repository "${mr[1]}" on GitHub. Planning execution.`,
    exec:async mr=>[{tool:'browser_navigate',params:{url:'https://github.com/new'},type:'nav',dur:300,res:'Loaded',act:()=>nav('https://github.com')},{tool:'github_create_repo',params:{name:mr[1],private:false},type:'mut',dur:1400,res:'Repository created'}],
    done:mr=>`Repository "${mr[1]}" is live at github.com/ncsound919/${mr[1]}. Want me to clone it or set up the project?`},
  {m:/deploy.*vercel|deploy.*production|\/deploy/i,ack:()=>'Starting deploy pipeline with pre-deploy audit check.',
    exec:async()=>[{tool:'audit_quick',params:{scan:'security',scope:'pre-deploy'},type:'aud',dur:600,res:'1 critical — must fix'},{tool:'terminal_execute',params:{command:'npm run lint && npm test && npm run build'},type:'mut',dur:2200,res:'Lint ✓, 12 tests ✓, Build ✓',act:()=>addTC('npm run lint && npm test && npm run build','✓ No linting errors\n✓ 12 tests passed (2.4s)\n✓ Build succeeded (3.2s)')},{tool:'vercel_deploy',params:{project:'my-project',env:'production'},type:'mut',dur:2400,res:'Live: my-project.vercel.app'}],
    done:()=>'Deploy blocked: 1 critical security finding (SQL injection in handlers.ts:89). Fix with `/fix` first, then redeploy. This is the audit system preventing incomplete deploys.'},
  {m:/commit.*push|push.*main|\/commit/i,ack:()=>'Staging, committing, and pushing. Running pre-commit audit first.',
    exec:async()=>[{tool:'audit_quick',params:{scan:'types,security'},type:'aud',dur:500,res:'0 critical — safe to commit'},{tool:'terminal_execute',params:{command:'git add -A && git commit -m "feat: update auth and api" && git push origin main'},type:'mut',dur:1200,res:'Pushed to origin/main',act:()=>addTC('git push origin main','a1b2c3d..a3f7b2e  main -> main')}],
    done:()=>'Changes pushed to main. Pre-commit audit passed (0 critical findings). Commit a3f7b2e.'},
  {m:/create.*pull.*request|open.*pr|\/pr/i,ack:()=>'Creating PR with audit summary included.',
    exec:async()=>[{tool:'terminal_execute',params:{command:'git log --oneline -5'},type:'read',dur:180,res:'5 commits',act:()=>addTC('git log --oneline -5','a3f7b2e feat: update auth\nb4c5d6e fix: token refresh')},{tool:'github_create_pr',params:{title:'feat: auth updates',body:'Includes pre-commit audit: 0 critical findings.'},type:'mut',dur:1200,res:'PR #43 created'}],
    done:()=>'PR #43 created with audit summary attached. All changes pre-verified.'},
  {m:/\/review|review.*code/i,ack:()=>'Running comprehensive code review with audit integration.',
    exec:async()=>[{tool:'terminal_execute',params:{command:'git diff HEAD~3'},type:'read',dur:300,res:'Diff loaded',act:()=>addTC('git diff HEAD~3','5 files changed, 142+, 38-')},{tool:'audit_full',params:{scope:'changed_files',categories:'security,race,smells'},type:'aud',dur:1800,res:'3 findings in changed code'},{tool:'ai_review',params:{focus:'correctness,security,performance'},type:'read',dur:1200,res:'Review complete'}],
    done:()=>'Review complete. Found 1 medium finding in changed code (race condition in token.ts:47 — concurrent requests can trigger multiple refreshes). Also: missing error handling in api.ts:112. Want me to fix these before merging?'},
  {m:/\/test|run.*test/i,ack:()=>'Running test suite with coverage analysis.',
    exec:async()=>[{tool:'terminal_execute',params:{command:'npm test -- --coverage'},type:'read',dur:1400,res:'12/12 passed, 78% coverage',act:()=>addTC('npm test','PASS src/auth.test.ts (3)\nPASS src/api.test.ts (9)\nTests: 12 passed (2.4s)\nCoverage: 78% statements')}],
    done:()=>'All 12 tests passing. Coverage: 78% statements, 72% branches, 69% functions. Lowest: utils/ at 34% — needs more tests.'},
  {m:/\/scan|security.*scan/i,ack:()=>'Running dedicated security scan.',
    exec:async()=>[{tool:'terminal_execute',params:{command:'npm audit'},type:'read',dur:800,res:'3 vulnerabilities',act:()=>addTC('npm audit','Critical: lodash prototype pollution\nHigh: axios SSRF\nMedium: jsonwebtoken key confusion')},{tool:'security_scan',params:{scope:'src/',type:'sast'},type:'aud',dur:1200,res:'1 SQL injection found'}],
    done:()=>'Security scan: 1 critical (SQL injection handlers.ts:89), 3 dependency CVEs. Run `/fix` to auto-patch the dependencies and I\'ll manually fix the SQL injection.'},
  {m:/debug.*(\w[\w\s]*)/i,ack:mr=>`Investigating: ${mr[1]}. I\'ll reproduce, trace execution, and identify root cause.`,
    exec:async()=>[{tool:'terminal_execute',params:{command:'npm test -- --reporter verbose 2>&1 | head -30'},type:'read',dur:800,res:'Error traced',act:()=>addTC('npm test --verbose','FAIL token refresh → expires during request\nExpected: 200, Received: 401')},{tool:'audit_race',params:{file:'src/auth/token.ts'},type:'aud',dur:1000,res:'Race condition confirmed'}],
    done:()=>'Root cause: race condition in token.ts:47. Concurrent requests trigger multiple refreshes; the second invalidates the first token. Fix: add a promise-memoized refresh that reuses the in-flight promise. Want me to implement this?'},
  {m:/opencode.*(?:refactor|implement|fix)/i,ack:()=>'Routing to OpenCode for local agent execution with full filesystem access.',
    exec:async()=>[{tool:'opencode_run',params:{task:'Refactor auth module',cwd:'/home/dev/projects/my-project'},type:'mut',dur:2600,res:'4 files modified'},{tool:'audit_quick',params:{scan:'types',scope:'changed_files'},type:'aud',dur:500,res:'0 new type issues'}],
    done:()=>'OpenCode completed the refactoring. 4 files modified. Post-change audit: 0 new type issues. Changes are unstaged — want me to review and commit?'},
  {m:/go\s+to\s+(.+)/i,ack:mr=>`Navigating to ${mr[1]}.`,exec:async mr=>[{tool:'browser_navigate',params:{url:mr[1].startsWith('http')?mr[1]:'https://'+mr[1]},type:'nav',dur:300,res:'Loaded',act:()=>{try{nav(mr[1].startsWith('http')?mr[1]:'https://'+mr[1])}catch(e){nav(mr[1])}}}],done:mr=>`Navigated to ${mr[1]}.`},
  {m:/\/explain|explain.*code/i,ack:()=>'Analyzing code for explanation.',exec:async()=>[{tool:'read_file',params:{path:'src/auth/token.ts'},type:'read',dur:400,res:'File loaded'}],done:()=>'This module handles JWT token lifecycle:\n1. **createToken()** — signs a new JWT with user claims\n2. **refreshToken()** — exchanges expired token for new one (has race condition on line 47)\n3. **validateToken()** — verifies signature and expiry\n4. **revokeToken()** — adds token to blocklist in Redis\n\nThe race condition occurs because two concurrent 401 responses both call refreshToken(), and the second refresh invalidates the first token.'},
  {m:/\/refactor|refactor.*code/i,ack:()=>'Analyzing code for refactoring opportunities with audit context.',exec:async()=>[{tool:'audit_smells',params:{scope:'src/auth'},type:'aud',dur:800,res:'3 smells found'},{tool:'ai_refactor',params:{target:'src/auth/',focus:'complexity,duplication'},type:'mut',dur:1800,res:'Refactoring plan generated'}],done:()=>'Refactoring opportunities found:\n1. **Extract TokenService** from AuthService (god class, 7 responsibilities)\n2. **Merge duplicate validation** logic in middleware.ts and routes.ts\n3. **Simplify login()** — complexity 18 → target 8\n\nShall I implement these changes?'},
];

async function processAgent(input){
  addMsg('user',esc(input));setBusy(true);await wait(250+Math.random()*250);

  // Handle slash commands
  if(input.startsWith('/')){
    const cmd=slashCmds.find(c=>input.startsWith(c.cmd));
    if(cmd){if(cmd.fn){const r=cmd.fn();if(r===null){setBusy(false);return}}else if(cmd.action){input=cmd.action+input.slice(cmd.cmd.length).trim()}}
  }

  let wf=null,mr=null;
  for(const w of wfs){const m=input.match(w.m);if(m){wf=w;mr=m;break}}

  if(wf){
    // Direct function calls (audit, quick audit)
    if(wf.fn){setBusy(false);wf.fn();return}

    await typeMsg(wf.ack(mr));await wait(200);
    let steps;
    try{steps=await wf.exec(mr)}catch(e){if(e==='denied'){await typeMsg('Operation denied. No changes made.');setBusy(false);return}throw e}
    const planEl=addPlanBlock(steps.map(s=>({label:s.tool,label:s.params?.action||s.params?.scan||s.tool,name:s.tool})));
    await wait(300);
    for(let i=0;i<steps.length;i++){
      const pEl=planEl.querySelectorAll('.plan-st');if(pEl[i])pEl[i].className='plan-st rn';
      const te=addToolBlk(steps[i].tool,steps[i].params,steps[i].type||'nav');
      if(steps[i].act)steps[i].act();
      await wait(steps[i].dur||800);
      completeTool(te,steps[i].dur||800,steps[i].res||'Done',!steps[i].res?.includes('critical')||steps[i].res?.includes('0 critical'));
      if(pEl[i])pEl[i].className='plan-st dn';
      await wait(150);
    }
    await wait(200);await typeMsg(wf.done(mr));toast('Task completed','ok');
  }else{
    const a=agents[S.activeAgent];
    await typeMsg(`I'm ${a.name}, your ${a.role.toLowerCase()}. I have access to 8 MCP servers, 9 skills from open-source repos, and a one-button audit system. Try:\n\n• /audit — full 7-scan audit\n• /audit-quick — security + types only\n• /fix — auto-fix findings\n• /deploy — deploy with audit gate\n• /review — AI code review\n\nOr describe what you need and I'll plan it.`);
  }
  setBusy(false);
}

function handleSend(){const i=$('#ci'),v=i.value.trim();if(!v||S.busy)return;i.value='';$('#slash-dd').classList.remove('show');processAgent(v)}
function agentCmd(cmd){if(S.busy)return;$('#ci').value=cmd;handleSend()}
 $('#ci').addEventListener('keydown',e=>{if(e.key==='Enter'&&!$('#slash-dd').classList.contains('show'))handleSend()});

function updSugs(u){const p=plat(u);const map={home:['/audit','/fix','/deploy','/review','/scan'],github:['/commit','/pr','/review','/audit'],vercel:['/deploy','/rollback','/env'],supabase:['/migrate','/audit'],cloudflare:['/deploy','/audit']};$('#sugs').innerHTML=(map[p]||map.home).map(s=>`<span class="sug" onclick="agentCmd('${s}')">${s}</span>`).join('')}

