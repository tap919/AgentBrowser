<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgentBrowser — Hermes Dev Environment</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,900&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --bg0:#060810;--bg1:#0b0e17;--bg2:#111625;--bg3:#1a2035;--bg4:#242e48;
  --brd:#222c44;--brd2:#33405e;--tx0:#e6eaf3;--tx1:#8692ae;--tx2:#4e5c78;--tx3:#354058;
  --acc:#e8a020;--acc2:#f5b840;--accg:rgba(232,160,32,.1);
  --tl:#14c4a8;--tlg:rgba(20,196,168,.1);--cy:#22b8d6;--cyg:rgba(34,184,214,.1);
  --em:#10b981;--rd:#ef4444;--or:#f97316;--rs:#f43f5e;
  --hermes:#a855f7;--hermesg:rgba(168,85,247,.1);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg0);color:var(--tx0);overflow:hidden;height:100vh}
code,pre,.mono{font-family:'JetBrains Mono',monospace}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--brd);border-radius:3px}

#app{display:grid;grid-template-rows:40px 1fr;grid-template-columns:50px 1fr 420px;height:100vh}
#topbar{grid-column:1/-1;background:var(--bg1);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 10px;gap:6px;z-index:50}
#sidebar{background:var(--bg1);border-right:1px solid var(--brd);display:flex;flex-direction:column;align-items:center;padding:8px 0;gap:2px;overflow-y:auto}
#main{display:flex;flex-direction:column;overflow:hidden;background:var(--bg2);position:relative}
#rpanel{background:var(--bg1);border-left:1px solid var(--brd);display:flex;flex-direction:column;overflow:hidden}

.addr{flex:1;max-width:500px;height:26px;background:var(--bg3);border:1px solid var(--brd);border-radius:7px;display:flex;align-items:center;padding:0 8px;gap:5px;transition:border-color .2s}
.addr:focus-within{border-color:var(--acc)}.addr input{flex:1;background:0;border:0;outline:0;color:var(--tx0);font-size:11px;font-family:'JetBrains Mono',monospace}
.nb{display:flex;gap:1px}.nb button{width:24px;height:24px;border:0;background:0;color:var(--tx2);border-radius:4px;cursor:pointer;font-size:10px;transition:all .12s}.nb button:hover{background:var(--bg3);color:var(--tx0)}
.tb{display:flex;gap:1px;flex:1;overflow-x:auto;padding:0 4px;scrollbar-width:none}.tb::-webkit-scrollbar{display:none}
.tab{display:flex;align-items:center;gap:4px;padding:2px 8px;border-radius:4px;font-size:10px;cursor:pointer;white-space:nowrap;color:var(--tx1);transition:all .1s;border:1px solid transparent}
.tab:hover{background:var(--bg3);color:var(--tx0)}.tab.on{background:var(--bg3);color:var(--tx0);border-color:var(--brd)}
.tab .x{opacity:0;font-size:8px;padding:1px;border-radius:2px;transition:all .1s}.tab:hover .x{opacity:.5}.tab .x:hover{opacity:1;background:var(--rd);color:#fff}
.tbtn{height:24px;padding:0 7px;border:0;background:0;color:var(--tx2);border-radius:4px;cursor:pointer;font-size:10px;display:flex;align-items:center;gap:4px;transition:all .12s}.tbtn:hover{background:var(--bg3);color:var(--tx0)}

.sb{width:34px;height:34px;border-radius:7px;border:0;background:0;color:var(--tx2);cursor:pointer;font-size:13px;transition:all .15s;display:flex;align-items:center;justify-content:center;position:relative}
.sb:hover{background:var(--bg3);color:var(--tx0)}.sb.on{background:var(--accg);color:var(--acc);box-shadow:inset 0 0 0 1px rgba(232,160,32,.2)}
.sb .dt{position:absolute;bottom:2px;right:2px;width:5px;height:5px;border-radius:50%;border:1.5px solid var(--bg1)}.sb .dt.g{background:var(--em)}.sb .dt.r{background:var(--tx3)}
.sb-sep{width:20px;height:1px;background:var(--brd);margin:3px 0}

#vp{flex:1;overflow-y:auto;position:relative}
.pg{padding:18px;animation:pgI .2s ease}@keyframes pgI{from{opacity:0;transform:translateY(3px)}to{opacity:1;transform:translateY(0)}}

#tw{height:0;background:var(--bg0);border-top:1px solid var(--brd);overflow:hidden;transition:height .2s ease}#tw.open{height:130px}
.tbar{display:flex;align-items:center;justify-content:space-between;padding:2px 8px;background:var(--bg1);border-bottom:1px solid var(--brd);font-size:9px;color:var(--tx2)}
.tbody{padding:4px 8px;font-family:'JetBrains Mono',monospace;font-size:10px;line-height:1.6;height:calc(100% - 20px);overflow-y:auto}
.tl{color:var(--tx1)}.tl .p{color:var(--acc)}.tl .c{color:var(--tx0)}.tl .o{color:var(--tx2)}

.rp-tabs{display:flex;border-bottom:1px solid var(--brd);flex-shrink:0;overflow-x:auto;scrollbar-width:none}.rp-tabs::-webkit-scrollbar{display:none}
.rp-t{padding:7px 5px;text-align:center;font-size:9px;font-weight:600;color:var(--tx2);cursor:pointer;border-bottom:2px solid transparent;transition:all .12s;white-space:nowrap;flex:1}
.rp-t:hover{color:var(--tx1);background:var(--bg3)}.rp-t.on{color:var(--acc);border-bottom-color:var(--acc);background:var(--accg)}
.rpc{flex:1;overflow-y:auto;display:none;padding:0}.rpc.on{display:flex;flex-direction:column}

.cm{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px}
.msg{animation:mI .2s ease}@keyframes mI{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.msg-u{align-self:flex-end;background:var(--bg4);border:1px solid var(--brd);border-radius:8px 8px 2px 8px;padding:7px 10px;font-size:12px;max-width:88%}
.msg-a{align-self:flex-start;max-width:94%;font-size:12px;line-height:1.55;color:var(--tx0)}
.msg-a .av{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:4px;font-size:8px;font-weight:800;margin-right:4px;vertical-align:middle;color:#000}
.av-hermes{background:var(--hermes)}.av-arch{background:#6366f1}.av-code{background:var(--acc)}.av-rev{background:var(--cy)}.av-dev{background:var(--em)}.av-res{background:var(--or)}

.plan-blk{background:var(--bg3);border:1px solid var(--brd);border-radius:6px;margin:4px 0;overflow:hidden;font-size:11px}
.plan-hdr{display:flex;align-items:center;gap:5px;padding:5px 8px;border-bottom:1px solid var(--brd);font-weight:600;font-size:10px}
.plan-st{display:flex;align-items:center;gap:6px;padding:5px 8px;border-bottom:1px solid rgba(34,44,68,.4);font-size:10.5px}
.plan-st:last-child{border-bottom:0}
.plan-st .sn{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--brd);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:var(--tx2);flex-shrink:0;transition:all .15s}
.plan-st.dn .sn{background:var(--em);border-color:var(--em);color:#fff}.plan-st.rn .sn{background:var(--acc);border-color:var(--acc);color:#000;animation:pp 1s infinite}.plan-st.pn .sn{border-color:var(--tx3);color:var(--tx3)}
@keyframes pp{0%,100%{transform:scale(1)}50%{transform:scale(.8)}}
.plan-st.dn .st{color:var(--em)}.plan-st.rn .st{color:var(--acc)}

.tool-blk{background:var(--bg3);border:1px solid var(--brd);border-radius:6px;margin:4px 0;overflow:hidden;font-size:10.5px;animation:tI .15s ease}
@keyframes tI{from{opacity:0;transform:scale(.98)}to{opacity:1;transform:scale(1)}}
.tool-h{display:flex;align-items:center;gap:5px;padding:5px 8px;border-bottom:1px solid var(--brd)}
.tool-h .ti{width:16px;height:16px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:7px;color:#fff;flex-shrink:0}
.tool-h .ti.nav{background:var(--cy)}.tool-h .ti.mut{background:var(--acc)}.tool-h .ti.read{background:var(--em)}.tool-h .ti.aud{background:var(--hermes)}
.tool-h .tn{font-weight:600;font-family:'JetBrains Mono',monospace;font-size:9.5px}.tool-h .ts{margin-left:auto;font-size:8.5px}.tool-h .ts.run{color:var(--acc)}.tool-h .ts.ok{color:var(--em)}
.tool-p{padding:5px 8px;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tx1);border-bottom:1px solid var(--brd)}
.tool-p .pk{color:var(--tl)}.tool-p .pv{color:var(--tx0)}
.tool-r{padding:5px 8px;font-size:9.5px;display:flex;align-items:center;gap:4px}
.tool-r.ok{color:var(--em)}.tool-r.err{color:var(--rd)}.tool-r.warn{color:var(--or)}

.appr-blk{background:var(--bg3);border:1px solid var(--or);border-radius:6px;margin:4px 0;padding:8px;font-size:11px}
.appr-blk .at{color:var(--or);font-weight:700;margin-bottom:3px;display:flex;align-items:center;gap:5px;font-size:10.5px}
.appr-blk .ad{color:var(--tx1);margin-bottom:6px;font-size:10.5px}
.abtn{display:flex;gap:5px}.abtn button{padding:4px 12px;border-radius:5px;border:0;font-size:10px;font-weight:600;cursor:pointer;transition:all .1s}
.ba{background:var(--em);color:#fff}.ba:hover{filter:brightness(1.15)}.bd{background:var(--bg4);color:var(--tx1);border:1px solid var(--brd)!important}

.ci{padding:8px 12px;border-top:1px solid var(--brd);display:flex;gap:5px;position:relative}
.ci input{flex:1;background:var(--bg3);border:1px solid var(--brd);border-radius:7px;padding:8px 10px;color:var(--tx0);font-size:12px;outline:0;transition:border-color .2s}
.ci input:focus{border-color:var(--acc)}.ci input::placeholder{color:var(--tx3)}
.sbtn{width:34px;height:34px;border-radius:7px;border:0;background:var(--hermes);color:#fff;cursor:pointer;font-size:12px;transition:all .1s;display:flex;align-items:center;justify-content:center}.sbtn:hover{filter:brightness(1.15)}.sbtn:disabled{opacity:.3;cursor:not-allowed}

.slash-dd{position:absolute;bottom:100%;left:12px;right:52px;background:var(--bg1);border:1px solid var(--brd);border-radius:8px;max-height:220px;overflow-y:auto;display:none;z-index:100;box-shadow:0 -4px 20px rgba(0,0,0,.4)}
.slash-dd.show{display:block}
.slash-item{display:flex;align-items:center;gap:7px;padding:6px 9px;cursor:pointer;transition:background .06s;font-size:10.5px}
.slash-item:hover,.slash-item.sel{background:var(--accg)}
.slash-item .si-icon{width:20px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0}
.slash-item .si-name{font-weight:600;flex:1}.slash-item .si-desc{color:var(--tx2);font-size:9px}

.sugs{padding:4px 12px;display:flex;gap:4px;flex-wrap:wrap;border-top:1px solid var(--brd)}
.sug{padding:2px 7px;border-radius:4px;border:1px solid var(--brd);background:var(--bg3);color:var(--tx1);font-size:9.5px;cursor:pointer;transition:all .1s;white-space:nowrap}
.sug:hover{border-color:var(--hermes);color:var(--hermes)}

/* Audit */
.audit-btn{background:linear-gradient(135deg,var(--hermes),#7c3aed);color:#fff;border:0;padding:8px 20px;border-radius:8px;font-weight:700;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .15s;box-shadow:0 0 20px rgba(168,85,247,.2)}
.audit-btn:hover{transform:translateY(-1px);box-shadow:0 0 30px rgba(168,85,247,.3)}
.audit-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.audit-scan{padding:10px 12px;border:1px solid var(--brd);border-radius:8px;background:var(--bg1);margin-bottom:6px;transition:all .15s}
.audit-scan:hover{border-color:var(--brd2)}
.audit-scan.running{border-color:var(--hermes);box-shadow:0 0 10px var(--hermesg)}
.audit-scan.done{border-color:var(--em)}
.audit-scan.failed{border-color:var(--rd)}
.audit-bar{height:4px;border-radius:2px;background:var(--bg3);overflow:hidden;margin-top:6px}
.audit-bar-fill{height:100%;border-radius:2px;transition:width .4s ease;background:var(--hermes)}
.audit-scan.done .audit-bar-fill{background:var(--em)}
.finding{padding:8px 10px;border-left:3px solid;border-radius:0 5px 5px 0;margin:4px 0;font-size:10.5px;background:var(--bg2)}
.finding.critical{border-color:var(--rd);background:rgba(239,68,68,.06)}.finding.high{border-color:var(--or);background:rgba(249,115,22,.06)}.finding.medium{border-color:var(--acc);background:rgba(232,160,32,.06)}.finding.low{border-color:var(--cy);background:rgba(34,184,214,.06)}.finding.info{border-color:var(--tx2);background:rgba(78,92,120,.06)}
.finding .fn{font-weight:700;font-size:9.5px;margin-bottom:2px;display:flex;align-items:center;gap:5px}
.finding .fd{color:var(--tx1);font-size:9.5px;line-height:1.4}
.finding .fl{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx2);margin-top:3px}
.sev{padding:1px 6px;border-radius:3px;font-size:8px;font-weight:700;text-transform:uppercase}
.sev-critical{background:rgba(239,68,68,.15);color:var(--rd)}.sev-high{background:rgba(249,115,22,.15);color:var(--or)}.sev-medium{background:rgba(232,160,32,.15);color:var(--acc)}.sev-low{background:rgba(34,184,214,.15);color:var(--cy)}.sev-info{background:rgba(78,92,120,.15);color:var(--tx2)}

/* Agent cards */
.agent-card{padding:10px;border:1px solid var(--brd);border-radius:7px;background:var(--bg2);margin-bottom:5px;cursor:pointer;transition:all .12s}
.agent-card:hover{border-color:var(--brd2)}.agent-card.on{border-color:var(--hermes);background:var(--hermesg)}
.agent-card .ac-name{font-weight:700;font-size:12px;display:flex;align-items:center;gap:6px;margin-bottom:3px}

/* MCP cards */
.mcp-card{padding:10px;border:1px solid var(--brd);border-radius:7px;background:var(--bg2);margin-bottom:5px}
.mcp-card .mc-name{font-weight:700;font-size:11px;display:flex;align-items:center;gap:5px;margin-bottom:3px}
.mcp-card .mc-cmd{font-family:'JetBrains Mono',monospace;font-size:8.5px;color:var(--tx2);background:var(--bg0);padding:3px 5px;border-radius:3px;margin-bottom:5px}
.mcp-card .mc-tools{display:flex;flex-wrap:wrap;gap:3px}
.tchip{padding:1px 5px;border-radius:3px;font-size:8px;font-family:'JetBrains Mono',monospace;background:var(--bg4);color:var(--tx1);border:1px solid var(--brd)}

/* Skill cards */
.skill-card{padding:10px;border:1px solid var(--brd);border-radius:7px;background:var(--bg2);margin-bottom:5px;cursor:pointer;transition:all .12s}
.skill-card:hover{border-color:var(--tl)}

/* Token vault */
.vault-row{display:flex;align-items:center;gap:6px;padding:6px 8px;border:1px solid var(--brd);border-radius:5px;background:var(--bg2);margin-bottom:4px;font-size:10px}
.vault-row .vr-key{font-weight:600;color:var(--tl);min-width:70px;font-size:9px}
.vault-row .vr-val{flex:1;color:var(--tx1);font-family:'JetBrains Mono',monospace;font-size:9px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.vault-row .vr-toggle{cursor:pointer;color:var(--tx3);font-size:9px;padding:2px 4px}.vault-row .vr-toggle:hover{color:var(--tx1)}

.badge{padding:1px 6px;border-radius:8px;font-size:8px;font-weight:700}
.badge-ok{background:rgba(16,185,129,.12);color:var(--em)}.badge-err{background:rgba(239,68,68,.12);color:var(--rd)}.badge-warn{background:rgba(249,115,22,.12);color:var(--or)}

#toasts{position:fixed;bottom:14px;right:14px;display:flex;flex-direction:column;gap:5px;z-index:999}
.toast{padding:7px 12px;border-radius:7px;font-size:10.5px;display:flex;align-items:center;gap:5px;transform:translateX(120%);transition:transform .2s ease;backdrop-filter:blur(10px)}
.toast.show{transform:translateX(0)}
.toast-ok{background:rgba(16,185,129,.14);border:1px solid rgba(16,185,129,.3);color:var(--em)}
.toast-err{background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.3);color:var(--rd)}
.toast-info{background:rgba(34,184,214,.14);border:1px solid rgba(34,184,214,.3);color:var(--cy)}

#cmd-pal{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:900;display:none;align-items:flex-start;justify-content:center;padding-top:12vh;backdrop-filter:blur(4px)}
#cmd-pal.show{display:flex}
#cmd-pal .cp-box{width:500px;background:var(--bg1);border:1px solid var(--brd);border-radius:10px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.5)}
#cmd-pal .cp-input{width:100%;background:var(--bg2);border:0;border-bottom:1px solid var(--brd);padding:11px 14px;color:var(--tx0);font-size:13px;outline:0}
.cp-item{display:flex;align-items:center;gap:9px;padding:7px 12px;cursor:pointer;transition:background .06s;font-size:11px}
.cp-item:hover,.cp-item.sel{background:var(--accg)}
.cp-item .ci-icon{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.cp-item .ci-label{font-weight:600;flex:1}.cp-item .ci-hint{color:var(--tx2);font-size:9px}

@media(max-width:1000px){#app{grid-template-columns:50px 1fr}#rpanel{display:none}}
@media(prefers-reduced-motion:reduce){*{animation-duration:0s!important;transition-duration:0s!important}}
</style>
</head>
<body>
<div id="app">
  <header id="topbar">
    <div class="nb"><button onclick="goBack()"><i class="fas fa-arrow-left"></i></button><button onclick="goFwd()"><i class="fas fa-arrow-right"></i></button><button onclick="refresh()"><i class="fas fa-rotate-right"></i></button></div>
    <div class="addr"><i class="fas fa-lock" style="color:var(--em);font-size:8px"></i><input id="url-in" type="text" value="agent://home" spellcheck="false" aria-label="Address bar"></div>
    <div class="tb" id="tab-bar"></div>
    <button class="tbtn" onclick="toggleTerm()" title="Terminal"><i class="fas fa-terminal"></i></button>
    <button class="tbtn" onclick="runFullAudit()" title="Run Audit" style="color:var(--hermes)"><i class="fas fa-shield-halved"></i></button>
    <button class="tbtn" onclick="showCmdPal()" title="Commands (Ctrl+P)"><i class="fas fa-magnifying-glass"></i></button>
  </header>

  <aside id="sidebar">
    <button class="sb on" data-p="home" onclick="nav('agent://home')" title="Home"><i class="fas fa-house"></i></button>
    <div class="sb-sep"></div>
    <button class="sb" data-p="github" onclick="nav('https://github.com')" title="GitHub"><i class="fab fa-github"></i><span class="dt g"></span></button>
    <button class="sb" data-p="vercel" onclick="nav('https://vercel.com')" title="Vercel"><i class="fas fa-play" style="font-size:10px"></i><span class="dt g"></span></button>
    <button class="sb" data-p="supabase" onclick="nav('https://supabase.com')" title="Supabase"><i class="fas fa-database"></i><span class="dt g"></span></button>
    <button class="sb" data-p="cloudflare" onclick="nav('https://dash.cloudflare.com')" title="Cloudflare"><i class="fas fa-cloud"></i><span class="dt r"></span></button>
    <div class="sb-sep"></div>
    <button class="sb" onclick="switchRP('agents')" title="Agents"><i class="fas fa-users"></i></button>
    <button class="sb" onclick="switchRP('mcps')" title="MCP Servers"><i class="fas fa-puzzle-piece"></i></button>
    <button class="sb" onclick="switchRP('skills')" title="Skills"><i class="fas fa-wand-magic-sparkles"></i></button>
    <button class="sb" onclick="switchRP('vault')" title="Token Vault"><i class="fas fa-key"></i></button>
    <div style="flex:1"></div>
    <button class="sb" onclick="runFullAudit()" title="Audit" style="color:var(--hermes)"><i class="fas fa-shield-halved"></i></button>
  </aside>

  <div id="main">
    <div id="vp"></div>
    <div id="tw"><div class="tbar"><span><i class="fas fa-terminal" style="margin-right:3px"></i>Terminal</span><button onclick="toggleTerm()" style="background:0;border:0;color:var(--tx2);cursor:pointer;font-size:9px"><i class="fas fa-xmark"></i></button></div><div class="tbody" id="tbody"></div></div>
  </div>

  <aside id="rpanel">
    <div class="rp-tabs">
      <div class="rp-t on" data-r="chat" onclick="switchRP('chat')">Chat</div>
      <div class="rp-t" data-r="agents" onclick="switchRP('agents')">Agents</div>
      <div class="rp-t" data-r="mcps" onclick="switchRP('mcps')">MCPs</div>
      <div class="rp-t" data-r="skills" onclick="switchRP('skills')">Skills</div>
      <div class="rp-t" data-r="vault" onclick="switchRP('vault')">Vault</div>
    </div>
