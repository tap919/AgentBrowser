<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgentBrowser — Push to GitHub</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,900&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--bg0:#050710;--bg1:#0a0d18;--bg2:#0f1422;--bg3:#182038;--bg4:#223050;--brd:#1e2a48;--brd2:#2a3c60;--tx0:#e8ecf6;--tx1:#8894b4;--tx2:#506080;--tx3:#354060;--acc:#d4a020;--acc2:#f0c040;--accg:rgba(212,160,32,.08);--tl:#10c4a0;--tlg:rgba(16,196,160,.08);--cy:#20b0d8;--em:#10b981;--rd:#ef4444;--or:#f08020;--h1:#a060e0;--h2:#8040c0;--hg:rgba(160,96,224,.08)}
*{margin:0;padding:0;box-sizing:border-box}body{font-family:'DM Sans',sans-serif;background:var(--bg0);color:var(--tx0);overflow:hidden;height:100vh}::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--brd);border-radius:3px}
#app{display:grid;grid-template-rows:52px 1fr;height:100vh}
#topbar{background:var(--bg1);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 20px;gap:12px;z-index:50}
#main{overflow-y:auto}
.logo{font-size:15px;font-weight:900;letter-spacing:-.5px;display:flex;align-items:center;gap:8px}.logo i{color:var(--h1);font-size:18px}.logo span{color:var(--h1)}
.tb-sep{width:1px;height:24px;background:var(--brd)}
.gh-btn{padding:6px 16px;border-radius:8px;border:0;background:#24292e;color:#fff;font-weight:700;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .15s}.gh-btn:hover{background:#2d3339;transform:translateY(-1px)}
.tbtn{height:32px;padding:0 12px;border:0;background:0;color:var(--tx2);border-radius:6px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:5px;transition:all .12s}.tbtn:hover{background:var(--bg3);color:var(--tx0)}

.page{max-width:900px;margin:0 auto;padding:28px 24px;animation:pgI .3s ease}@keyframes pgI{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.card{background:var(--bg1);border:1px solid var(--brd);border-radius:14px;padding:24px;margin-bottom:16px}
.card-title{font-size:20px;font-weight:900;margin-bottom:4px}
.card-sub{font-size:13px;color:var(--tx1);margin-bottom:20px;line-height:1.5}

.fg{margin-bottom:18px}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--tx1);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.fg input,.fg textarea,.fg select{width:100%;background:var(--bg0);border:1px solid var(--brd);border-radius:8px;padding:10px 14px;color:var(--tx0);font-size:13px;outline:0;transition:border-color .2s;font-family:'DM Sans',sans-serif}
.fg input:focus,.fg textarea:focus{border-color:var(--h1)}
.fg textarea{resize:vertical;min-height:80px;line-height:1.6}
.fg .hint{font-size:10px;color:var(--tx2);margin-top:4px;line-height:1.4}

.opt-row{display:flex;gap:8px;flex-wrap:wrap}
.opt{padding:8px 14px;border-radius:6px;border:1.5px solid var(--brd);background:var(--bg2);cursor:pointer;font-size:11px;font-weight:600;transition:all .15s;display:flex;align-items:center;gap:5px}
.opt:hover{border-color:var(--brd2)}.opt.on{border-color:var(--h1);background:var(--hg);color:var(--h1)}

.push-btn{width:100%;padding:14px;border-radius:10px;border:0;background:linear-gradient(135deg,#24292e,#2d3339);color:#fff;font-size:15px;font-weight:800;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.push-btn:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(36,41,46,.4)}.push-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.push-btn.purple{background:linear-gradient(135deg,var(--h1),var(--h2))}

.sec-box{padding:12px;border:1px solid rgba(239,68,68,.3);border-radius:8px;background:rgba(239,68,68,.04);margin-bottom:16px;font-size:11px;line-height:1.5;color:var(--tx1)}
.sec-box .sec-title{color:var(--rd);font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:5px}

/* Progress */
.progress-bar{height:4px;border-radius:2px;background:var(--bg3);overflow:hidden;margin:12px 0}
.progress-fill{height:100%;border-radius:2px;transition:width .4s ease;background:var(--h1)}

.step-list{display:flex;flex-direction:column;gap:6px;margin-top:12px}
.step-item{display:flex;align-items:center;gap:8px;font-size:11px;padding:6px 10px;border-radius:6px;background:var(--bg2)}
.step-item .si-dot{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0}
.si-wait{background:var(--bg3);color:var(--tx3)}.si-run{background:var(--h1);color:#fff;animation:spulse 1.5s infinite}.si-ok{background:var(--em);color:#fff}.si-fail{background:var(--rd);color:#fff}
@keyframes spulse{0%,100%{box-shadow:0 0 8px rgba(160,96,224,.3)}50%{box-shadow:0 0 16px rgba(160,96,224,.5)}}
.step-item .si-text{flex:1;color:var(--tx1)}.step-item .si-text b{color:var(--tx0)}
.step-item .si-detail{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* Success state */
.success-card{text-align:center;padding:32px}
.success-icon{width:64px;height:64px;border-radius:50%;background:rgba(16,185,129,.1);border:2px solid var(--em);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:24px;color:var(--em)}
.success-title{font-size:22px;font-weight:900;margin-bottom:6px}
.success-sub{font-size:13px;color:var(--tx1);margin-bottom:20px}

.link-card{display:flex;align-items:center;gap:12px;padding:14px;border:1px solid var(--brd);border-radius:10px;background:var(--bg2);margin-bottom:8px;cursor:pointer;transition:all .15s;text-align:left}
.link-card:hover{border-color:var(--h1);background:var(--hg)}
.link-card .lc-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.link-card .lc-name{font-weight:700;font-size:12px}.link-card .lc-url{font-size:10px;color:var(--tl);font-family:'JetBrains Mono',monospace}

#toasts{position:fixed;bottom:16px;right:16px;display:flex;flex-direction:column;gap:5px;z-index:999}
.toast{padding:8px 14px;border-radius:8px;font-size:11px;display:flex;align-items:center;gap:6px;transform:translateX(120%);transition:transform .25s;backdrop-filter:blur(10px)}
.toast.show{transform:translateX(0)}
.toast-ok{background:rgba(16,185,129,.14);border:1px solid rgba(16,185,129,.3);color:var(--em)}
.toast-err{background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.3);color:var(--rd)}
.toast-info{background:rgba(32,176,216,.14);border:1px solid rgba(32,176,216,.3);color:var(--cy)}
@media(prefers-reduced-motion:reduce){*{animation-duration:0s!important;transition-duration:0s!important}}
</style>
</head>
<body>
<div id="app">
  <header id="topbar">
    <div class="logo"><i class="fas fa-hexagon-check"></i><span>AgentBrowser</span></div>
    <div class="tb-sep"></div>
    <div style="flex:1"></div>
    <button class="tbtn" onclick="showPage('setup')"><i class="fas fa-gear"></i>Setup</button>
    <button class="gh-btn" onclick="startPush()"><i class="fab fa-github"></i>Push to GitHub</button>
  </header>
  <div id="main"></div>
</div>
<div id="toasts"></div>

<script>
const $=s=>document.querySelector(s);
const wait=ms=>new Promise(r=>setTimeout(r,ms));
const esc=s=>s?.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')||'';

/* ═══════════════════════════════════════════
   STATE
   ═══════════════════════════════════════════ */
let token=localStorage.getItem('gh_token')||'';
let ghUser=null;
let pushState='setup'; // setup | pushing | success | error
let pushSteps=[];
let repoUrl='';

/* ═══════════════════════════════════════════
   TOAST
   ═══════════════════════════════════════════ */
function toast(msg,t='ok'){const e=document.createElement('div');e.className=`toast toast-${t}`;e.innerHTML=`<i class="fas fa-${t==='ok'?'check-circle':t==='err'?'circle-exclamation':'circle-info'}"></i> ${msg}`;$('#toasts').appendChild(e);requestAnimationFrame(()=>e.classList.add('show'));setTimeout(()=>{e.classList.remove('show');setTimeout(()=>e.remove(),250)},3500)}

/* ═══════════════════════════════════════════
   GITHUB API HELPERS
   ═══════════════════════════════════════════ */
async function ghApi(endpoint,method='GET',body=null){
  const opts={method,headers:{'Authorization':`token ${token}`,'Accept':'application/vnd.github.v3+json','Content-Type':'application/json'}};
  if(body)opts.body=JSON.stringify(body);
  const res=await fetch(`https://api.github.com${endpoint}`,opts);
  if(!res.ok){const err=await res.json().catch(()=>({message:'Unknown error'}));throw new Error(err.message||`HTTP ${res.status}`)}
  return res.json();
}

async function getGHUser(){
  if(ghUser)return ghUser;
  ghUser=await ghApi('/user');
  return ghUser;
}

/* ═══════════════════════════════════════════
   PAGES
   ═══════════════════════════════════════════ */
function showPage(page){
  if(page==='setup')renderSetup();
  else if(page==='pushing')renderPushing();
  else if(page==='success')renderSuccess();
  else if(page==='error')renderError();
}

function renderSetup(){
  pushState='setup';
  const hasToken=!!token;
  $('#main').innerHTML=`<div class="page" style="max-width:640px">
  <div class="card">
    <div class="card-title"><i class="fab fa-github" style="margin-right:6px"></i>Push to GitHub</div>
    <div class="card-sub">Create a new repository on your GitHub account and upload the AgentBrowser project files. Everything happens right here in your browser — no terminal needed.</div>

    <div class="sec-box">
      <div class="sec-title"><i class="fas fa-triangle-exclamation"></i>Security</div>
      Your token is stored in your browser's local storage and is only sent to GitHub's API (api.github.com). It is never logged, transmitted elsewhere, or shared. If you want to remove it, click "Clear Token" below or clear your browser data.
    </div>

    <div class="fg">
      <label>GitHub Personal Access Token</label>
      <div style="display:flex;gap:6px">
        <input type="password" id="f-token" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" value="${hasToken?'••••••••••••':''}" style="flex:1" onfocus="if(this.value==='••••••••••••')this.value=''">
        <button onclick="testToken()" style="padding:8px 14px;border-radius:8px;border:1px solid var(--brd);background:var(--bg2);color:var(--tx1);font-size:11px;cursor:pointer;font-weight:600;transition:all .12s;white-space:nowrap" onmouseover="this.style.borderColor='var(--em)'" onmouseout="this.style.borderColor='var(--brd)'"><i class="fas fa-plug" style="margin-right:3px"></i>Test</button>
      </div>
      <div class="hint">Needs <code style="background:var(--bg3);padding:1px 4px;border-radius:3px;font-size:9px">repo</code> scope. Create one at <a href="https://github.com/settings/tokens/new" target="_blank" style="color:var(--tl)">github.com/settings/tokens/new</a></div>
      <div id="token-status" style="margin-top:6px"></div>
    </div>

    <div class="fg">
      <label>Repository Name</label>
      <input type="text" id="f-repo" value="agentbrowser" placeholder="my-project">
      <div class="hint">This becomes the URL: github.com/your-name/agentbrowser</div>
    </div>

    <div class="fg">
      <label>Description</label>
      <input type="text" id="f-desc" value="AI-powered autonomous project builder with quality gates, audit system, and one-click deployment" placeholder="What this project does">
    </div>

    <div class="fg">
      <label>Visibility</label>
      <div class="opt-row">
        <div class="opt on" data-vis="public" onclick="selectVis('public')"><i class="fas fa-globe" style="font-size:10px"></i>Public</div>
        <div class="opt" data-vis="private" onclick="selectVis('private')"><i class="fas fa-lock" style="font-size:10px"></i>Private</div>
      </div>
    </div>

    <div class="fg">
      <label>Files to Include</label>
      <div style="display:flex;flex-direction:column;gap:4px">
        <label style="display:flex;align-items:center;gap:6px;font-size:11px;cursor:pointer"><input type="checkbox" checked disabled style="accent-color:var(--h1)">index.html <span style="color:var(--tx2);font-size:9px">— Main application</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:11px;cursor:pointer"><input type="checkbox" checked disabled style="accent-color:var(--h1)">README.md <span style="color:var(--tx2);font-size:9px">— Project documentation</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:11px;cursor:pointer"><input type="checkbox" checked style="accent-color:var(--h1)" id="f-lic">LICENSE <span style="color:var(--tx2);font-size:9px">— MIT License</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:11px;cursor:pointer"><input type="checkbox" checked style="accent-color:var(--h1)" id="f-gitignore">.gitignore <span style="color:var(--tx2);font-size:9px">— Standard ignores</span></label>
      </div>
    </div>

    ${hasToken?`<button class="push-btn purple" onclick="startPush()"><i class="fas fa-cloud-arrow-up"></i>Create Repo and Push Files</button>`:`<button class="push-btn" disabled><i class="fas fa-lock"></i>Enter Your Token First</button>`}
  </div>
</div>`;
}

let selectedVis='public';
function selectVis(v){selectedVis=v;document.querySelectorAll('[data-vis]').forEach(e=>e.classList.toggle('on',e.dataset.vis===v))}

async function testToken(){
  const input=$('#f-token');
  const t=input.value.trim();
  if(!t||t==='••••••••••••'){toast('Enter a token first','err');return}
  token=t;
  const status=$('#token-status');
  status.innerHTML='<span style="color:var(--acc);font-size:10px"><i class="fas fa-spinner fa-spin" style="margin-right:3px"></i>Testing...</span>';
  try{
    const user=await getGHUser();
    token=t;localStorage.setItem('gh_token',t);
    status.innerHTML=`<span style="color:var(--em);font-size:10px"><i class="fas fa-check-circle" style="margin-right:3px"></i>Connected as <b>${esc(user.login)}</b> — token valid</span>`;
    toast(`Connected to ${user.login}`,'ok');
    // Re-render to enable push button
    setTimeout(()=>renderSetup(),800);
  }catch(e){
    status.innerHTML=`<span style="color:var(--rd);font-size:10px"><i class="fas fa-circle-exclamation" style="margin-right:3px"></i>${esc(e.message)}</span>`;
    toast('Token test failed','err');
  }
}

/* ═══════════════════════════════════════════
   PUSH PIPELINE
   ═══════════════════════════════════════════ */
async function startPush(){
  const t=$('#f-token')?.value?.trim()||token;
  if(t&&t!=='••••••••••••'){token=t;localStorage.setItem('gh_token',t)}

  if(!token){toast('Enter your GitHub token first','err');showPage('setup');return}

  const repoName=($('#f-repo')?.value?.trim())||'agentbrowser';
  const repoDesc=($('#f-desc')?.value?.trim())||'AI-powered autonomous project builder';
  const includeLic=$('#f-lic')?.checked??true;
  const includeGi=$('#f-gitignore')?.checked??true;

  pushSteps=[
    {id:'auth',text:'Authenticate with GitHub',detail:''},
    {id:'repo',text:`Create repository <b>${esc(repoName)}</b>`,detail:''},
    {id:'html',text:'Upload index.html',detail:'~85 KB'},
    {id:'readme',text:'Upload README.md',detail:''},
    {id:'license',text:'Upload LICENSE',detail:'',skip:!includeLic},
    {id:'gitignore',text:'Upload .gitignore',detail:'',skip:!includeGi},
    {id:'verify',text:'Verify repository is accessible',detail:''},
  ];

  pushState='pushing';
  renderPushing();

  try{
    // Step 1: Auth
    updateStep('auth','run');
    const user=await getGHUser();
    updateStep('auth','ok',user.login);
    await wait(300);

    // Step 2: Create repo
    updateStep('repo','run');
    const repo=await ghApi('/user/repos','POST',{
      name:repoName,description:repoDesc,private:selectedVis==='private',auto_init:false
    });
    repoUrl=repo.html_url;
    updateStep('repo','ok',repo.full_name);
    await wait(300);

    const owner=user.login;
    const branch='main';

    // Step 3: Upload index.html
    updateStep('html','run');
    const htmlContent=btoa(unescape(encodeURIComponent(getHTMLFile(repoName))));
    await ghApi(`/repos/${owner}/${repoName}/contents/index.html`,'PUT',{
      message:'feat: initial AgentBrowser application',content:htmlContent,branch
    });
    updateStep('html','ok','uploaded');
    await wait(200);

    // Step 4: Upload README
    updateStep('readme','run');
    const readmeContent=btoa(unescape(encodeURIComponent(getReadmeFile(repoName,repoDesc))));
    await ghApi(`/repos/${owner}/${repoName}/contents/README.md`,'PUT',{
      message:'docs: add project README',content:readmeContent,branch
    });
    updateStep('readme','ok','uploaded');
    await wait(200);

    // Step 5: LICENSE
    if(includeLic){
      updateStep('license','run');
      const licContent=btoa(unescape(encodeURIComponent(getLicenseFile())));
      await ghApi(`/repos/${owner}/${repoName}/contents/LICENSE`,'PUT',{
        message:'license: add MIT license',content:licContent,branch
      });
      updateStep('license','ok','uploaded');
      await wait(200);
    }

    // Step 6: .gitignore
    if(includeGi){
      updateStep('gitignore','run');
      const giContent=btoa(unescape(encodeURIComponent(getGitignoreFile())));
      await ghApi(`/repos/${owner}/${repoName}/contents/.gitignore`,'PUT',{
        message:'chore: add .gitignore',content:giContent,branch
      });
      updateStep('gitignore','ok','uploaded');
      await wait(200);
    }

    // Step 7: Verify
    updateStep('verify','run');
    const verify=await ghApi(`/repos/${owner}/${repoName}`);
    updateStep('verify','ok',`${verify.size} KB`);

    pushState='success';
    renderSuccess();
    toast('Repository created and files pushed!','ok');

  }catch(e){
    // Mark current running step as failed
    const runStep=pushSteps.find(s=>s.status==='run');
    if(runStep)updateStep(runStep.id,'fail',e.message);
    pushState='error';
    renderError(e.message);
    toast('Push failed: '+e.message,'err');
  }
}

function updateStep(id,status,detail=''){
  const step=pushSteps.find(s=>s.id===id);
  if(step){step.status=status;step.detail=detail}
  renderPushing();
}

function renderPushing(){
  const done=pushSteps.filter(s=>s.status==='ok').length;
  const total=pushSteps.filter(s=>!s.skip).length;
  const pct=Math.round((done/total)*100);

  $('#main').innerHTML=`<div class="page" style="max-width:640px">
  <div class="card">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
      <i class="fab fa-github" style="font-size:20px"></i>
      <span style="font-size:18px;font-weight:900">Pushing to GitHub</span>
    </div>
    <div style="font-size:12px;color:var(--tx1);margin-bottom:16px">Creating repository and uploading project files...</div>

    <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
    <div style="font-size:10px;color:var(--tx2);text-align:center;margin-bottom:12px">${pct}% complete</div>

    <div class="step-list">
      ${pushSteps.map(s=>{
        if(s.skip)return'';
        const cls=s.status==='ok'?'si-ok':s.status==='run'?'si-run':s.status==='fail'?'si-fail':'si-wait';
        const icon=s.status==='ok'?'check':s.status==='run'?'spinner fa-spin':s.status==='fail'?'xmark':'circle';
        return`<div class="step-item"><span class="si-dot ${cls}"><i class="fas fa-${icon}"></i></span><span class="si-text">${s.text}</span><span class="si-detail">${esc(s.detail)}</span></div>`;
      }).join('')}
    </div>
  </div>
</div>`;
}

function renderSuccess(){
  const repoName=($('#f-repo')?.value?.trim())||'agentbrowser';
  $('#main').innerHTML=`<div class="page" style="max-width:640px">
  <div class="card success-card">
    <div class="success-icon"><i class="fas fa-check"></i></div>
    <div class="success-title">Your Project Is on GitHub</div>
    <div class="success-sub">Repository created and all files pushed successfully.</div>

    <div style="text-align:left;margin-bottom:20px">
      <div class="link-card" onclick="window.open('${repoUrl}','_blank')">
        <div class="lc-icon" style="background:rgba(240,240,240,.08);color:#f0f0f0"><i class="fab fa-github"></i></div>
        <div><div class="lc-name">Source Code</div><div class="lc-url">${esc(repoUrl)}</div></div>
        <i class="fas fa-arrow-up-right-from-square" style="color:var(--tx3);font-size:11px"></i>
      </div>
      <div class="link-card" onclick="window.open('${repoUrl}/issues','_blank')">
        <div class="lc-icon" style="background:rgba(240,128,32,.08);color:var(--or)"><i class="fas fa-circle-dot"></i></div>
        <div><div class="lc-name">Issues</div><div class="lc-url">${esc(repoUrl)}/issues</div></div>
        <i class="fas fa-arrow-up-right-from-square" style="color:var(--tx3);font-size:11px"></i>
      </div>
      <div class="link-card" onclick="window.open('${repoUrl}/actions','_blank')">
        <div class="lc-icon" style="background:var(--tlg);color:var(--tl)"><i class="fas fa-play"></i></div>
        <div><div class="lc-name">Actions</div><div class="lc-url">${esc(repoUrl)}/actions</div></div>
        <i class="fas fa-arrow-up-right-from-square" style="color:var(--tx3);font-size:11px"></i>
      </div>
    </div>

    <div style="display:flex;gap:8px;justify-content:center">
